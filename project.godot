; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text if you know what you're doing.

[application]

config/name="Speelklok Galerij"
run/main_scene="res://galerij.tscn"
config/features=PackedStringArray("4.6", "Forward Mobile")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"
window/stretch/aspect="keep"
